  <script>
    $(document).ready(function() {
      // Cơ sở dữ liệu 20 bài viết thực tế đồng bộ 100% theo file mẫu news.html của bạn
      const articlesDatabase = {
0: {
          id: 0,
          type: "promo",
          tag: "Tin Khuyến Mãi",
          title: "Độc bản mùa yêu: Đặc quyền quà tặng tinh tế dịp lễ kết hôn 2026",
          date: "02/06/2026",
          img: "https://www.messika.com/media/opti_image/webp/catalog/product/cache/c55b1599846e2e4d518f44ada8803512/m/e/messika_-_outfit_1_1_-_bague_move_uno_pav_e_05630_wg.webp",
          content: `
            <p class="article-lead font-serif italic text-lg text-primary/80 mb-6">Đón chào mùa chung đôi tràn ngập cảm hứng duy mỹ, Vane Vietnam trân trọng gửi tặng chương trình đặc quyền lớn nhất năm dành riêng cho ngày trọng đại của các cặp đôi.</p>
            
            <p>Mùa cưới năm 2026 chứng kiến sự lên ngôi mạnh mẽ của những giá trị Bespoke cá nhân hóa sâu sắc. Từ ngày 02/06 đến hết ngày 30/06/2026, Vane trân trọng gửi tới các cặp đôi đặc quyền <span class="highlight-badge">Ưu dẫn 10%</span> áp dụng trực tiếp cho toàn bộ các gói đặt thiết kế và chế tác nhẫn cưới Bespoke độc bản.</p>
            
            <h2 class="font-serif text-2xl text-primary pt-4 pb-2">1. Kiệt tác kim hoàn kết tinh từ lòng kiên nhẫn</h2>
            <p>Tại xưởng chế tác trung tâm của Vane, một chiếc nhẫn cưới không bao giờ được tạo ra từ dây chuyền công nghiệp đại trà. Mỗi phôi vàng nguyên khối đều phải trải qua hàng chục giờ mài dũa, nung chảy và định hình hoàn toàn bằng đôi bàn tay của các nghệ nhân trưởng lão.</p>
            
            <div class="article-inner-img">
              <img src="https://www.messika.com/media/opti_image/webp/catalog/product/cache/c55b1599846e2e4d518f44ada8803512/m/e/messika_-_packshot_-_bague_move_uno_pav_e_vue_3_05630_wg_1.webp" alt="Quy trình chế tác nhẫn cưới Bespoke tại Vane">
              <span class="img-caption">Mỗi tạo tác nhẫn cưới Bespoke tại Vane đều trải qua hơn 80 giờ mài dũa thủ công nghiêm ngặt trước khi bàn giao.</span>
            </div>

            <p>Bên cạnh mức chiết khấu <span class="highlight-text">Đặc Quyền 10%</span>, Vane Vietnam còn dành tặng một chương trình nghệ thuật cá nhân hóa đi kèm: <span class="highlight-badge">Miễn Phí 100%</span> chi phí chạm khắc thủ công các ký tự mật mã, ngày kỷ niệm lên mặt trong của lòng nhẫn.</p>
            <blockquote class="article-quote font-serif italic text-xl text-gold pl-6 border-l-2 border-gold my-6">"Tín vật trăm năm của một tình yêu chính trực xứng đáng nhận được sự nâng niu và bảo bọc trong những tạo tác duy mỹ tuyệt đối."</blockquote>
            
            <h2 class="font-serif text-2xl text-primary pt-4 pb-2">2. Quà tặng da thuộc di sản – Nâng niu giá trị vĩnh cửu</h2>
            <p>Để nối dài trải nghiệm thượng lưu, mọi đơn hàng hoàn thiện trong tháng 6 này sẽ nhận kèm một món quà tri kỷ: Khay đựng trang sức tư gia cao cấp chế tác từ chất liệu da thuộc Ý nguyên tấm.</p>

            <div class="article-inner-img">
              <img src="https://flexhouse.vn/wp-content/uploads/2023/05/YS07-2-1-800x800.jpg" alt="Khay trang sức da thuộc cao cấp tặng kèm">
              <span class="img-caption">Khay da thuộc cao cấp mang sắc màu Ivory đồng điệu, một mảnh ghép hoàn hảo cho không gian tư gia của quý khách.</span>
            </div>

            <p>Chương trình tri ân mùa kết hôn với mức <span class="highlight-text">Ưu đãi 10% và Gift Set Da Thuộc</span> sẽ giới hạn lượt tiếp đón để đảm bảo tính chu đáo tối đa. Quý khách có thể liên hệ đặt lịch hẹn trước với các đại sứ không gian của Vane.</p>
          `
        },

       1: {
          id: 1, 
          type: "promo", 
          tag: "Tin Khuyến Mãi",
          title: "Private Sales: Chương trình tri ân đặc quyền dành cho khách hàng thân thiết", 
          date: "15/05/2026", 
          img: "https://www.messika.com/media/opti_image/webp/catalog/product/cache/c55b1599846e2e4d518f44ada8803512/m/e/messika_-_outfit_1_1_-_bracelet_baby_move_classique_pav_04325_-_collier_baby_move_classique_pav_wg_1.webp",
          content: `
            <p class="article-lead font-serif italic text-lg text-primary/80 mb-6">Chương trình Private Sales kín đáo – lời tri ân đặc biệt dành riêng cho những tri kỷ đã luôn đồng hành và thấu hiểu giá trị di sản của Vane Vietnam.</p>
            
            <p>Để gửi lời cảm ơn sâu sắc đến quý thượng khách, Vane trân trọng tổ chức tuần lễ trải nghiệm không gian đóng Private Sales. Đây là dịp để quý khách sở hữu những tạo tác kim hoàn thuộc bộ sưu tập di sản cổ điển với mức đặc quyền <span class="highlight-badge">Ưu đãi lên tới 15%</span>.</p>
            
            <h2 class="font-serif text-2xl text-primary pt-4 pb-2">Không gian thưởng lãm xa xỉ thầm lặng</h2>
            <p>Sự kiện được thiết kế riêng tư tại showroom, nơi quý khách có thể thoải mái chiêm ngưỡng và thử các dòng trang sức cao cấp nhất mà không bị làm phiền. Mỗi món quà tri ân đều được các nghệ nhân chọn lọc kỹ lưỡng, đảm bảo tính thẩm mỹ và sự sang trọng điềm đạm đúng tinh thần thương hiệu.</p>

            <div class="article-inner-img my-8">
              <img src="https://i.pinimg.com/736x/c6/d2/59/c6d2594ac075476a4816ea769bd554f6.jpg" alt="Không gian Private Sales VIP">
              <span class="img-caption">Không gian tiếp đón riêng tư mang đậm tinh thần nghệ thuật Indochine trầm mặc và quý phái.</span>
            </div>

            <p>Đặc biệt, trong khuôn khổ chương trình, quý khách sẽ nhận thêm ưu đãi <span class="highlight-text">Giảm 15% Toàn Bộ Tạo Tác</span> sẵn có. Đây là cơ hội hiếm hoi để sưu tầm những món trang sức di sản vốn thường xuyên trong tình trạng cháy hàng hoặc chỉ được sản xuất với số lượng giới hạn.</p>
            
            <blockquote class="article-quote font-serif italic text-xl text-gold pl-6 border-l-2 border-gold my-6">"Private Sales không đơn thuần là mua sắm, đó là sự tôn vinh mối giao hảo giữa những người cùng yêu cái đẹp bền vững."</blockquote>
            
            <p>Sự kiện chỉ áp dụng cho khách hàng sở hữu thư mời định danh từ ban điều hành. Hãy kiểm tra hộp thư hoặc liên hệ trực tiếp với đại sứ tư vấn của bạn để nhận mã xác nhận tham dự.</p>
          `
        },

        2: {
          id: 2, 
          type: "promo", 
          tag: "Tin Khuyến Mãi",
          title: "The Art of Gifting: Chạm khắc ký tự độc bản miễn phí tri ân ngày của Mẹ",
          date: "05/05/2026", 
          img: "https://www.messika.com/media/opti_image/webp/catalog/product/cache/52f8d614d5bbd2d588afa5e471fce85a/m/e/messika_paris_-_collier_messika_fiery_13239_p.webp",
          content: `
            <p class="article-lead font-serif italic text-lg text-primary/80 mb-6">Món quà thiêng liêng lưu giữ ký ức, kính dâng những người Mẹ tôn quý bằng ngôn ngữ của kim hoàn di sản.</p>
            
            <p>Tôn vinh tình mẫu tử thiêng liêng trong tháng 5, Vane Vietnam trân trọng ra mắt chương trình "The Art of Gifting". Đây là dịp để quý khách gửi trao yêu thương qua những tạo tác độc bản, với đặc quyền <span class="highlight-badge">Miễn Phí 100%</span> chi phí chạm khắc thủ công các ký tự chữ ký, ngày kỷ niệm hoặc thông điệp gia đình lên mặt trong của mọi dây chuyền vàng cao cấp.</p>
            
            <h2 class="font-serif text-2xl text-primary pt-4 pb-2">Nét chạm khắc tinh hoa từ đôi tay nghệ nhân</h2>
            <p>Mỗi món trang sức dành tặng Mẹ không chỉ là một món quà, đó là một kỷ vật lưu giữ thời gian. Nghệ nhân của Vane thực hiện việc chạm khắc thủ công với sự tập trung cao độ, đảm bảo từng nét chữ đều mảnh mai nhưng sắc sảo, bền bỉ cùng năm tháng.</p>

            <div class="article-inner-img my-8">
              <img src="https://www.messika.com/media/opti_image/webp/catalog/product/cache/c55b1599846e2e4d518f44ada8803512/m/e/messika_-_packshot_-_bague_move_noa_cisel_e_gm_vue_3_14499_pg.webp" alt="Nghệ nhân chạm khắc thủ công">
              <span class="img-caption">Quy trình khắc thủ công đòi hỏi sự tỉ mỉ để không ảnh hưởng đến bề mặt vàng nguyên khối.</span>
            </div>

            <p>Chương trình tài trợ <span class="highlight-text">Miễn Phí Toàn Bộ Chi Phí Khắc Chữ</span> là lời tri ân chân thành mà Vane muốn cùng quý khách viết nên câu chuyện tình thân vĩnh cửu. Dù đó là một lời nhắn nhủ yêu thương, hay ngày sinh nhật của Mẹ, chúng tôi đều hiện thực hóa nó thành một tác phẩm nghệ thuật có linh hồn.</p>
            
            <blockquote class="article-quote font-serif italic text-xl text-gold pl-6 border-l-2 border-gold my-6">"Có những lời yêu thương khó nói thành lời, hãy để nghệ thuật kim hoàn thay bạn thì thầm cùng Mẹ."</blockquote>
            
            <p>Đây là cơ hội để biến món quà thông thường thành một báu vật độc bản. Quý khách vui lòng ghé thăm các không gian trải nghiệm của Vane để được tư vấn thiết kế thông điệp ý nghĩa nhất trước khi nghệ nhân bắt đầu thực hiện.</p>
          `
        },

        3: {
          id: 3, 
          type: "promo", 
          tag: "Tin Khuyến Mãi",
          title: "Ưu đãi thẻ đặc quyền di sản khi sở hữu BST Vàng Trắng Đông Dương", 
          date: "20/04/2026", 
          img: "https://www.messika.com/media/opti_image/webp/catalog/product/cache/c55b1599846e2e4d518f44ada8803512/m/e/messika_-_outfit_1_1_-_mono_boucles_d_oreille_clip_move_uno_pampille_pav_11162_-_mono_boucles_d_oreille_puce_move_uno_12957_wg.webp",
          content: `
            <p class="article-lead font-serif italic text-lg text-primary/80 mb-6">Tôn vinh những giá trị văn hóa bất hủ qua hơi thở của kim hoàn hiện đại, bộ sưu tập Vàng Trắng Đông Dương là lời tri ân gửi tới những tâm hồn trân quý di sản.</p>
            
            <p>Để đánh dấu cột mốc kỷ niệm 20 năm hình thành và phát triển, Vane Vietnam trân trọng mang đến chương trình đặc quyền dành riêng cho chủ nhân sở hữu các tác phẩm thuộc BST Vàng Trắng Đông Dương. Quý khách hàng sẽ được nâng hạng trực tiếp lên thẻ VIP Vane Heritage, mở ra thế giới đặc quyền đẳng cấp với gói bảo dưỡng và xi mạ bạch kim <span class="highlight-badge">Miễn Phí Trọn Đời</span>.</p>
            
            <h2 class="font-serif text-2xl text-primary pt-4 pb-2">Vàng trắng 18K – Ánh sáng vĩnh cửu của thời gian</h2>
            <p>Chất liệu vàng trắng trong bộ sưu tập Đông Dương được tinh chế từ những kim loại quý hiếm, mang sắc trắng lạnh sang trọng và độ bền vượt trội. Chúng tôi hiểu rằng, những tạo tác mang giá trị lịch sử cần được bảo quản bằng kỹ thuật chuyên sâu để giữ trọn vẻ đẹp như ngày đầu.</p>

            <div class="article-inner-img my-8">
              <img src="https://www.messika.com/media/opti_image/webp/catalog/product/cache/c55b1599846e2e4d518f44ada8803512/m/e/messika_-_packshot_-_boucles_d_oreilles_puces_move_uno_vue_4_12305_wg_1.webp" alt="BST Vàng Trắng Đông Dương">
              <span class="img-caption">Những thiết kế trong BST Đông Dương là sự giao thoa hoàn hảo giữa nét cổ điển Á Đông và sự sắc sảo của hình khối đương đại.</span>
            </div>

            <p>Đặc quyền <span class="highlight-text">Miễn Phí Xi Mạ Bạch Kim Vô Điều Kiện</span> không chỉ là một dịch vụ, mà là cam kết của Vane trong việc duy trì vẻ đẹp nguyên bản của tín vật. Dù sau bao nhiêu năm tháng, tạo tác của quý khách vẫn sẽ luôn sáng bóng, phản chiếu ánh hào quang của những giá trị trường tồn.</p>
            
            <blockquote class="article-quote font-serif italic text-xl text-gold pl-6 border-l-2 border-gold my-6">"Chúng tôi bảo tồn di sản bằng cả đôi bàn tay, để những câu chuyện Đông Dương tiếp tục tỏa sáng cùng quý chủ nhân."</blockquote>
            
            <p>Quý khách vui lòng mang theo thẻ chứng nhận di sản khi đến bất kỳ showroom nào của Vane để kích hoạt gói đặc quyền này. Đây là cơ hội để quý khách an tâm tận hưởng vẻ đẹp của bộ sưu tập mà không phải lo lắng về những tác động của thời gian lên bề mặt kim loại quý.</p>
          `
        },

        4: {
