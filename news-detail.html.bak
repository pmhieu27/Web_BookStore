</head>
<body class="bg-white text-charcoal font-sans opacity-0 transition-opacity duration-500 antialiased">

  <!-- LOADER BLOCK -->
  <div id="loader" class="fixed inset-0 z-200 bg-ivory flex items-center justify-center">
    <div class="font-logo text-2xl tracking-[0.4em]">VANE</div>
  </div>

  <!-- HEADER CỐ ĐỊNH (DYNAMIC GLOBAL INJECTED) -->
  <div id="component-header"></div>

  <main>

<section class="pt-40 pb-8 bg-white">
      <div class="max-w-6xl mx-auto px-8 flex flex-col items-start w-full">
        <nav class="mb-6">
          <ol class="flex items-center gap-2 font-ui text-[13px] tracking-wider text-muted">
            <li><a href="index.html" class="hover:text-primary transition-colors">Trang Chủ</a></li>
            <li class="text-silver">/</li>
            <li><a href="news.html" class="hover:text-primary transition-colors font-semibold">Tin Tức</a></li>
            <li class="text-silver">/</li>
            <li id="detail-crumb" class="text-primary line-clamp-1">Chi tiết bài viết</li>
          </ol>
        </nav>
        
        <span id="detail-tag" class="font-ui text-[10px] uppercase tracking-[0.2em] text-gold font-semibold mb-3 block">Tạp chí</span>
        <h1 id="detail-title" class="font-serif text-2xl sm:text-3xl md:text-5xl text-primary tracking-wide leading-tight mb-6">
          Đang kết nối câu chuyện di sản...
        </h1>
        
        <div class="flex items-center gap-4 border-t border-gray-100 pt-4 w-full font-ui text-[11px] text-muted tracking-wider">
          <span><i class="fa-regular fa-user mr-1.5"></i>Bởi Ban biên tập Vane</span>
          <span>•</span>
          <span><i class="fa-regular fa-calendar mr-1.5"></i><span id="detail-date">--/--/----</span></span>
        </div>
      </div>
    </section>

    <!-- PHẦN 2: ẢNH BANNER ĐẠI DIỆN ĐỘNG (Tỷ lệ khung hình 21:10 tạp chí cao cấp) -->
    <section class="max-w-5xl mx-auto px-6 mb-12">
      <div class="w-full aspect-[21/10] overflow-hidden bg-charcoal/5 border border-gray-100">
        <img id="detail-main-img" src="" alt="" class="w-full h-full object-cover">
      </div>
    </section>

    <!-- PHẦN 3: NỘI DUNG CHI TIẾT BÀI BÁO (Khóa khung đọc tối ưu thị giác) -->
    <section class="bg-white pb-20 px-4 md:px-6">
      <div class="max-w-3xl mx-auto">
        
        <div id="detail-content" class="detail-article-content text-justify space-y-6">
          <!-- Văn bản chi tiết giàu định dạng sẽ tự động đổ ra tại đây -->
        </div>

        <!-- KHỐI CHIA SẺ MẠNG XÃ HỘI & ĐƯỜNG LINK TRỞ VỀ TRANG NEWS -->
        <div class="flex items-center justify-between border-y border-gray-100 py-6 mt-12 font-ui text-xs w-full">

          <!-- Bên trái -->
          <a href="news.html"
            class="text-gold hover:text-primary font-bold uppercase tracking-widest flex items-center gap-1.5 transition-colors">
              <i class="fa-solid fa-arrow-left text-[9px]"></i>
              Trở về tạp chí
          </a>

          <!-- Bên phải -->
          <div class="flex items-center gap-3">
              <span class="text-muted uppercase tracking-wider font-semibold">
                  Chia sẻ:
              </span>

              <a id="share-facebook" target="_blank"
                class="w-8 h-8 rounded-full border border-charcoal/10 flex items-center justify-center text-muted hover:text-primary hover:border-charcoal transition-all">
                  <i class="fa-brands fa-facebook-f text-[11px]"></i>
              </a>

              <a id="share-pinterest" target="_blank"
                class="w-8 h-8 rounded-full border border-charcoal/10 flex items-center justify-center text-muted hover:text-primary hover:border-charcoal transition-all">
                  <i class="fa-brands fa-pinterest-p text-[11px]"></i>
              </a>

              <button id="copy-link"
                      class="w-8 h-8 rounded-full border border-charcoal/10 flex items-center justify-center text-muted hover:text-primary hover:border-charcoal transition-all">
                  <i class="fa-solid fa-link text-[11px]"></i>
              </button>
          </div>
      </div>

      <script>
      document.addEventListener("DOMContentLoaded", () => {
          const currentUrl = encodeURIComponent(window.location.href);
          const pageTitle = encodeURIComponent(document.title);

          // Facebook
          document.getElementById("share-facebook").href =
              `https://www.facebook.com/sharer/sharer.php?u=${currentUrl}`;

          // Pinterest
          document.getElementById("share-pinterest").href =
              `https://pinterest.com/pin/create/button/?url=${currentUrl}&description=${pageTitle}`;

          // Copy link
          document.getElementById("copy-link").addEventListener("click", async () => {
              try {
                  await navigator.clipboard.writeText(window.location.href);
                  alert("Đã sao chép liên kết!");
              } catch (err) {
                  console.error(err);
                  alert("Không thể sao chép liên kết.");
              }
          });
      });
      </script>
    </section>

    <!-- PHẦN 4: GỢI Ý BÀI VIẾT LIÊN QUAN ĐỘNG (Tự động liên kết mượt mà sang các bài khác) -->
